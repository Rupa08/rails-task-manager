<h1 class="mb-3"><%= @task.title %></h1>

<p class="lead"><%= @task.details %></p>

<p class="mt-3">
  <% if @task.completed %>
    <i class="fa-solid fa-square-check text-success fs-3"></i>
    <span class="ms-2">This task is completed</span>
  <% else %>
    <i class="fa-regular fa-square fs-3"></i>
    <span class="ms-2">This task is not completed yet</span>
  <% end %>
</p>

<div class="mt-4 d-flex gap-3">
  <%= link_to "Edit this task", edit_task_path(@task), class: "btn btn-warning" %>
  <%= link_to "Back to list", tasks_path, class: "btn btn-secondary" %>
</div>
